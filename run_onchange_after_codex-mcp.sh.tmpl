#!/usr/bin/env bash
# Declaratively register the mcpproxy gateway as a Codex MCP server.
# Codex's ~/.codex/config.toml is stateful (per-project trust levels, hook
# hashes), so it is NOT chezmoi-managed wholesale. Instead we drive Codex's own
# config writer here so the [mcp_servers.mcpproxy] block stays valid and in sync.
# Re-runs whenever this script's contents change (run_onchange).
#
# Codex can fail before shell wrappers run, so store the downstream mcpproxy
# bearer token directly in Codex's own MCP block. This mirrors the other
# HTTP-client configs and avoids depending on shell-provided environment.
set -euo pipefail

command -v codex >/dev/null 2>&1 || exit 0
command -v op >/dev/null 2>&1 || exit 0

mcpproxy_gateway_url={{ .mcpproxy_gateway_url | quote }}

# Idempotent: upsert only the [mcp_servers.mcpproxy] block while leaving the
# rest of Codex's stateful config.toml untouched.
MCPPROXY_GATEWAY_URL="$mcpproxy_gateway_url" python3 - <<'PY'
import os
import pathlib
import re
import subprocess

cfg = pathlib.Path.home() / ".codex" / "config.toml"
token = subprocess.check_output(
    ["op", "read", "op://clankers/mcpproxy-agents/password"],
    text=True,
).strip()
text = cfg.read_text()
pattern = re.compile(r"(?ms)^\[mcp_servers\.mcpproxy\]\n.*?(?=^\[|\Z)")
block = (
    '[mcp_servers.mcpproxy]\n'
    f'url = "{os.environ["MCPPROXY_GATEWAY_URL"].replace(chr(34), chr(92) + chr(34))}"\n'
    'http_headers = '
    + chr(123)
    + f' Authorization = "Bearer {token.replace(chr(34), chr(92) + chr(34))}" '
    + chr(125)
    + '\n\n'
)
if pattern.search(text):
    text = pattern.sub(block, text, count=1)
else:
    if text and not text.endswith("\n"):
        text += "\n"
    text += "\n" + block
cfg.write_text(text)
PY
