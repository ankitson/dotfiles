#!/usr/bin/env node
// Declaratively register the mcpproxy gateway as a Codex MCP server.
// Codex's ~/.codex/config.toml is stateful (per-project trust levels, plugin
// state, hook hashes), so it is NOT chezmoi-managed wholesale. Instead we drive
// Codex's own config writer here so the [mcp_servers.mcpproxy] block stays
// valid and in sync.
// Re-runs whenever this script's contents change (run_onchange).
//
// Written in Node.js (rather than bash+python) because python3 is not
// installed on Windows hosts, where Codex Desktop also runs.

const fs = require("fs");
const os = require("os");
const path = require("path");
const { execFileSync } = require("child_process");

const GATEWAY_URL = {{ .mcpproxy_gateway_url | quote }};

const cfg = path.join(os.homedir(), ".codex", "config.toml");
if (!fs.existsSync(path.dirname(cfg))) process.exit(0);

let token;
try {
  token = execFileSync("op", ["read", "op://clankers/mcpproxy-agents/password"], { encoding: "utf8" }).trim();
} catch {
  process.exit(0);
}

const escapeQuotes = (s) => s.replace(/"/g, '\\"');
const block =
  "[mcp_servers.mcpproxy]\n" +
  `url = "${escapeQuotes(GATEWAY_URL)}"\n` +
  `http_headers = { Authorization = "Bearer ${escapeQuotes(token)}" }\n\n`;

let text = fs.existsSync(cfg) ? fs.readFileSync(cfg, "utf8") : "";

// Idempotent: upsert only the [mcp_servers.mcpproxy] block while leaving the
// rest of Codex's stateful config.toml untouched. Walk line-by-line because
// JS regex has no end-of-string anchor that works with /m the way Python's
// \Z does — a tempered greedy match here is more legible than the workaround.
const lines = text.split("\n");
const SECTION = "[mcp_servers.mcpproxy]";
const SECTION_HEADER_RE = /^\[[^\]]+\]/;

let start = lines.findIndex((l) => l.trim() === SECTION);
if (start === -1) {
  if (text.length > 0 && !text.endsWith("\n")) text += "\n";
  text += "\n" + block;
} else {
  let end = lines.length;
  for (let i = start + 1; i < lines.length; i++) {
    if (SECTION_HEADER_RE.test(lines[i])) {
      end = i;
      break;
    }
  }
  const before = lines.slice(0, start).join("\n");
  const after = lines.slice(end).join("\n");
  text = (before ? before + "\n" : "") + block + after;
}

fs.writeFileSync(cfg, text);
