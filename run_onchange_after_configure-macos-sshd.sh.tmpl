{{ if and (eq .chezmoi.os "darwin") .personal -}}
#!/usr/bin/env bash
# Managed by chezmoi. Enables macOS Remote Login (sshd) and installs a hardened,
# Tailscale-only sshd drop-in. `run_onchange` re-runs this whenever the script or
# the embedded config (.chezmoitemplates/sshd_config_tailscale_secure.conf) change.
#
# Needs sudo — `chezmoi apply` will prompt for your password the first time and
# whenever the config changes. Safe to re-run: it's idempotent and validates the
# new config with `sshd -t`, rolling back on any error so you can't lock yourself
# out via a bad config (it does NOT, however, validate that your key is present —
# see below).
#
# NOTE: AuthenticationMethods is publickey-only. Make sure your public key is in
# ~/.ssh/authorized_keys (chezmoi deploys it on `personal` machines) BEFORE you
# depend on remote access, or you'll be locked out from non-console logins.
set -euo pipefail

CONF_DST="/etc/ssh/sshd_config.d/010-tailscale-secure.conf"

# Render the desired drop-in (chezmoi inlines the partial at apply time). The
# quoted heredoc delimiter prevents the shell from touching the contents.
TMP="$(mktemp)"
trap 'rm -f "$TMP"' EXIT
cat > "$TMP" <<'SSHDCONF'
{{ template "sshd_config_tailscale_secure.conf" . }}
SSHDCONF

# 1. Enable Remote Login (sshd) if it isn't already on. -f suppresses the
#    interactive security warning prompt.
remote_login="$(sudo systemsetup -getremotelogin 2>/dev/null | awk '{print $NF}')"
if [ "$remote_login" != "On" ]; then
  echo "Enabling Remote Login (sshd)…"
  sudo systemsetup -f -setremotelogin on
else
  echo "Remote Login already on."
fi

# 2. Install the hardened drop-in only if it differs, validating before commit.
if sudo test -f "$CONF_DST" && sudo cmp -s "$TMP" "$CONF_DST"; then
  echo "$CONF_DST already current."
else
  backup=""
  if sudo test -f "$CONF_DST"; then
    backup="${CONF_DST}.bak.$$"
    sudo cp -p "$CONF_DST" "$backup"
  fi
  sudo install -m 644 -o root -g wheel "$TMP" "$CONF_DST"
  if ! sudo /usr/sbin/sshd -t; then
    echo "ERROR: sshd config failed validation — rolling back." >&2
    if [ -n "$backup" ]; then sudo mv "$backup" "$CONF_DST"; else sudo rm -f "$CONF_DST"; fi
    exit 1
  fi
  [ -n "$backup" ] && sudo rm -f "$backup"
  echo "Installed and validated $CONF_DST"
fi

echo "sshd is configured: pubkey-only, restricted to Tailscale + trusted local IPs."
{{ end -}}
