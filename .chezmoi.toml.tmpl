{{/* boolean feature tags */}}
{{- $personal := false -}}{{/* true if this machine should have secrets from 1Password */}}
{{- $is_devbox := false -}}
{{- $is_homeserver := false -}}
{{- $is_agent := false -}}{{/* true if running as an automated agent (service account) */}}
{{- $internal_network := false -}}{{/* true if on home LAN with access to git.home.ankitson.com */}}
{{- "" -}}

{{- $osID := .chezmoi.os -}}
{{- if (and (eq .chezmoi.os "linux") (hasKey .chezmoi.osRelease "id")) -}}
{{-   $osID = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
{{- end -}}

{{- $hostname := .chezmoi.hostname -}}

{{- if env "OP_SERVICE_ACCOUNT_TOKEN" -}}
{{-   $is_agent = true -}}
{{-   $personal = true -}}{{/* agents still need secrets deployed */}}
{{-   $is_devbox = true -}}
{{- else if eq $hostname "desktop-linux" -}}
{{-   $personal = true -}}
{{-   $is_homeserver = true -}}
{{-   $internal_network = true -}}
{{- else if eq $hostname "devbox" -}}
{{-   $personal = true -}}
{{-   $is_devbox = true -}}
{{-   $internal_network = true -}}
{{- else if stdinIsATTY -}}
{{-   $personal = promptBoolOnce . "personal" "personal (1Password secrets)" -}}
{{- end -}}

{{- $email := "dev@ankitson.com" -}}

{{/* Auto-detect Java */}}
{{- $javaHome := "" -}}
{{- if lookPath "java" -}}
{{-   $javaHome = output "bash" "-c" "readlink -f $(which java) | sed 's|/bin/java$||'" | trim -}}
{{- end -}}

{{/* Auto-detect CUDA */}}
{{- $cudaPath := "" -}}
{{- if stat "/usr/local/cuda" -}}
{{-   $cudaPath = "/usr/local/cuda" -}}
{{- end -}}

{{/* This machine keeps its chezmoi source as a submodule under the devdocker
     repo rather than the default ~/.local/share/chezmoi. Emit sourceDir so that
     `chezmoi init` regenerating this config doesn't reset to the default path.
     Guarded by stat so it's a no-op on machines without that checkout. */ -}}
{{ if stat "/projects/devdocker/dotfiles" -}}
sourceDir = "/projects/devdocker/dotfiles"

{{ end -}}
[data]
    email = {{ $email | quote }}
    hostname = {{ $hostname | quote }}
    personal = {{ $personal }}
    is_devbox = {{ $is_devbox }}
    is_homeserver = {{ $is_homeserver }}
    is_agent = {{ $is_agent }}
    internal_network = {{ $internal_network }}
    osid = {{ $osID | quote }}
    javaHome = {{ $javaHome | quote }}
    cudaPath = {{ $cudaPath | quote }}

[github]
    refreshPeriod = "12h"

{{/* chezmoi's built-in interpreters don't include node, but several scripts
     (e.g. run_onchange_after_claude-desktop-mcp.js) need it on Windows where
     the kernel won't honor a "#!/usr/bin/env node" shebang. Map it here so
     `chezmoi apply` can execute *.js scripts on every platform. */ -}}
[interpreters.js]
    command = "node"

{{/* Use 1Password service-account mode wherever a service token is present
     (agents, plus hosts that source ~/.config/op/service-account.env). Interactive
     machines without the token fall back to the default account mode. */ -}}
{{ if or $is_agent (env "OP_SERVICE_ACCOUNT_TOKEN") -}}
[onepassword]
    mode = "service"
{{ end -}}
