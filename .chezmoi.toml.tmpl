{{/* machine feature tags */}}
{{- $identity := "none" -}}{{/* none | personal | agent. none = no secrets; personal & agent both deploy 1Password secrets, from op://Private (as Ankit) vs op://clankers (as the agent) */}}
{{- $host := "generic" -}}{{/* generic | devbox | homeserver — which machine environment this is */}}
{{- $internal_network := false -}}{{/* DEPRECATED: no longer read. Tailscale reaches internal hosts from anywhere now, so there's no LAN-only path left to gate. */}}
{{- "" -}}

{{- $osID := .chezmoi.os -}}
{{- if (and (eq .chezmoi.os "linux") (hasKey .chezmoi.osRelease "id")) -}}
{{-   $osID = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
{{- end -}}

{{- $hostname := .chezmoi.hostname -}}

{{- if env "OP_SERVICE_ACCOUNT_TOKEN" -}}
{{-   $identity = "agent" -}}
{{-   $host = "devbox" -}}
{{- else if eq $hostname "desktop-linux" -}}
{{-   $identity = "personal" -}}
{{-   $host = "homeserver" -}}
{{- else if eq $hostname "devbox" -}}
{{-   $identity = "personal" -}}
{{-   $host = "devbox" -}}
{{- else if stdinIsATTY -}}
{{-   if promptBoolOnce . "personal" "personal (1Password secrets)" -}}
{{-     $identity = "personal" -}}
{{-   end -}}
{{- end -}}

{{- $email := "dev@ankitson.com" -}}

{{/* Auto-detect Java */}}
{{- $javaHome := "" -}}
{{- if lookPath "java" -}}
{{-   $javaHome = output "bash" "-c" "readlink -f $(which java) | sed 's|/bin/java$||'" | trim -}}
{{- end -}}

{{/* Auto-detect CUDA */}}
{{- $cudaPath := "" -}}
{{- if stat "/usr/local/cuda" -}}
{{-   $cudaPath = "/usr/local/cuda" -}}
{{- end -}}

{{/* This machine keeps its chezmoi source as a submodule under the devdocker
     repo rather than the default ~/.local/share/chezmoi. Emit sourceDir so that
     `chezmoi init` regenerating this config doesn't reset to the default path.
     Guarded by stat so it's a no-op on machines without that checkout. */ -}}
{{ if stat "/projects/devdocker/dotfiles" -}}
sourceDir = "/projects/devdocker/dotfiles"

{{ end -}}
umask = 0o022

[data]
    email = {{ $email | quote }}
    hostname = {{ $hostname | quote }}
    identity = {{ $identity | quote }}
    host = {{ $host | quote }}
    osid = {{ $osID | quote }}
    javaHome = {{ $javaHome | quote }}
    cudaPath = {{ $cudaPath | quote }}

[github]
    refreshPeriod = "12h"

{{/* chezmoi's built-in interpreters don't include node, but several scripts
     (e.g. run_onchange_after_claude-desktop-mcp.js) need it on Windows where
     the kernel won't honor a "#!/usr/bin/env node" shebang. Map it here so
     `chezmoi apply` can execute *.js scripts on every platform. */ -}}
[interpreters.js]
    command = "node"

{{ if eq $identity "agent" -}}
[onepassword]
    mode = "service"
{{ end -}}
