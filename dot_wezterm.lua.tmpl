-- Status hint when passthrough is active
wezterm.on('update-right-status', function(window, _pane)
  if window:active_key_table() == 'passthrough' then
    window:set_right_status('PASS')
  else
    window:set_right_status('')
  end
end)

-- Stable tab title formatting:
-- - keep path-only fallback titles (drop user/host prefix)
-- - truncate total tab title length
-- - cache fallback title per tab id to avoid oscillation with dynamic pane titles
local MAX_TAB_TITLE_LEN = 28
local tab_title_cache = {}

local function truncate_text(text, max_len)
  if not text or #text <= max_len then
    return text
  end
  if max_len <= 3 then
    return text:sub(1, max_len)
  end
  return text:sub(1, max_len - 3) .. '...'
end

local function extract_path_title(text)
  if not text or #text == 0 then
    return text
  end

  -- Prefer the path from titles like "user@host: /path" or "host: /path".
  local path = text:match('^[^:]+:%s*(.+)$')
  if path and #path > 0 then
    return path
  end

  return text
end

wezterm.on('format-tab-title', function(tab, _tabs, _panes, _cfg, _hover, _max_width)
  local ok, computed = pcall(function()
    local limit = MAX_TAB_TITLE_LEN

    if tab.tab_title and #tab.tab_title > 0 then
      return truncate_text(extract_path_title(tab.tab_title), limit)
    end

    local tab_id = tab.tab_id
    if tab_id ~= nil then
      local cached = tab_title_cache[tab_id]
      if cached and #cached > 0 then
        return truncate_text(cached, limit)
      end
    end

    local pane = tab.active_pane
    local fallback = pane and pane.title or ''
    fallback = extract_path_title(fallback)
    if fallback and #fallback > 0 then
      if tab_id ~= nil then
        tab_title_cache[tab_id] = fallback
      end
      return truncate_text(fallback, limit)
    end

    return tostring(tab.tab_index + 1)
  end)

  local num = tostring(tab.tab_index + 1)
  if ok and computed and #computed > 0 then
    return num .. ':' .. computed
  end
  return num
end)

-- =========================
-- 1Password session sharing
-- =========================
-- Reads ~/.op_session (written by op_signin in the shell) and sets the
-- OP_SESSION_* env var for every new pane/tab.  WezTerm watches the file
-- and reloads config automatically when the session changes.
do
  local op_session_path = wezterm.home_dir .. '/.op_session'
  wezterm.add_to_config_reload_watch_list(op_session_path)

  local env = {}
  local f = io.open(op_session_path, 'r')
  if f then
    for line in f:lines() do
      local key, val = line:match('^export%s+([%w_]+)=(.*)')
      if key and val then
        env[key] = val
      end
    end
    f:close()
  end

  config.set_environment_variables = env
end

return config
