-- Status hint when passthrough is active
wezterm.on('update-right-status', function(window, _pane)
  if window:active_key_table() == 'passthrough' then
    window:set_right_status('PASS')
  else
    window:set_right_status('')
  end
end)

-- Auto-name tabs based on running command
wezterm.on('format-tab-title', function(tab, tabs, panes, config, hover, max_width)
  local title = tab.tab_title
  -- If the tab title is explicitly set via set_title, use that
  if title and #title > 0 then
    return title
  end

  local pane = tab.active_pane

  -- Try to get the process name from the foreground process (works for local panes)
  local process_name = pane.foreground_process_name
  if process_name then
    -- Extract just the basename of the process
    title = process_name:match("([^/\\]+)$") or process_name
    return title
  end

  -- Fall back to pane title (useful for remote SSH sessions)
  title = pane.title
  if title and #title > 0 then
    -- For SSH sessions, the title often contains "user@host: /path"
    -- Try to extract just the meaningful part
    local ssh_title = title:match("^[^:]+:%s*(.+)") or title
    -- If it's a path, get just the basename
    ssh_title = ssh_title:match("([^/]+)/?$") or ssh_title
    return ssh_title
  end

  -- Last resort: use tab index
  return tostring(tab.tab_index + 1)
end)

-- =========================
-- 1Password session sharing
-- =========================
-- Reads ~/.op_session (written by op_signin in the shell) and sets the
-- OP_SESSION_* env var for every new pane/tab.  WezTerm watches the file
-- and reloads config automatically when the session changes.
do
  local op_session_path = wezterm.home_dir .. '/.op_session'
  wezterm.add_to_config_reload_watch_list(op_session_path)

  local env = {}
  local f = io.open(op_session_path, 'r')
  if f then
    for line in f:lines() do
      local key, val = line:match('^export%s+([%w_]+)=(.*)')
      if key and val then
        env[key] = val
      end
    end
    f:close()
  end

  config.set_environment_variables = env
end

return config
