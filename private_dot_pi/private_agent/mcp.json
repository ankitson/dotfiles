{
  "mcpServers": {
    "agentmemory": {
      "command": "npx",
      "args": ["-y", "@agentmemory/mcp@0.9.24"],
      "env": {
        "AGENTMEMORY_URL": "${AGENTMEMORY_URL}"
      },
      "lifecycle": "lazy"
    },
    "fastmail": {
      "url": "https://api.fastmail.com/mcp",
      "auth": "oauth",
      "autoAuth": true,
      "lifecycle": "lazy",
      "directTools": [
        "list_mailboxes",
        "get_recent_emails",
        "list_calendars"
      ]
    }
  }
}
