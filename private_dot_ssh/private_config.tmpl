HashKnownHosts no

Host *
  # will exit in 12s if server goes to sleep
  ServerAliveInterval 3
  ServerAliveCountMax 4

Host github.com
  User git

Host git.home.ankitson.com
  Port 1024

{{/* SSH hosts — generated from the shared device inventory stored in 1Password:
     op://clankers/device-inventory/notesPlain (TOML). Each device with an
     `ssh` table becomes a Host entry keyed by its name, connecting to that
     device's explicit `hostname`. Edit the inventory note, not this file. */ -}}
{{- $inventory := (onepasswordRead "op://clankers/device-inventory/notesPlain" | fromToml) -}}
{{- range $inventory.devices }}{{ if hasKey . "ssh" }}{{ $ssh := .ssh }}
Host {{ .name }}
  HostName {{ .hostname }}
  User {{ dig "user" "ankit" $ssh }}
{{- $port := dig "port" "" $ssh }}{{ if $port }}
  Port {{ $port }}
{{- end }}
{{ end }}{{ end -}}
