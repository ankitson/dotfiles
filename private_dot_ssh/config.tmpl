HashKnownHosts no

Host *
  # will exit in 12s if server goes to sleep
  ServerAliveInterval 3
  ServerAliveCountMax 4

Host github.com
  User git

{{ if .internal_network -}}
Host git.home.ankitson.com
  Port 1024
{{ end -}}

Host desktop desktop-linux
  HostName 172.16.0.208
  User ankit

Host devbox
  HostName 172.16.0.208
  Port 2201
  User ankit

Host synology
  HostName 192.168.1.15
  User ankit
{{/* Tailscale hosts — generated from the shared inventory in 1Password
     (op://clankers/tailscale-inventory), devices with an `ssh:` block. Primary
     alias is ts-<name>; connects over MagicDNS (<name>.<tailnet>). Requires op
     auth at apply time (host has OP_SERVICE_ACCOUNT_TOKEN). */ -}}
{{- $ts := (onepasswordRead "op://clankers/tailscale-inventory/notesPlain" | fromYaml).tailscale -}}
{{- range $ts.devices }}{{ if hasKey . "ssh" }}{{ $ssh := .ssh }}
{{- $alias := .name }}{{ if not (hasPrefix "ts-" .name) }}{{ $alias = printf "ts-%s" .name }}{{ end }}
Host {{ $alias }}{{ range (dig "aliases" (list) $ssh) }} {{ . }}{{ end }}
  HostName {{ .name }}.{{ $ts.tailnet }}
  User {{ dig "user" "ankit" $ssh }}
{{- $port := dig "port" "" $ssh }}{{ if $port }}
  Port {{ $port }}
{{- end }}
{{ end }}{{ end -}}
