{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "litellm": {
      "name": "LiteLLM",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://litellm.home.ankitson.com/v1",
        "apiKey": {{ onepasswordRead "op://clankers/litellm/password" | quote }}
      },
      // Models are populated at startup by the litellm-live-models plugin
      // (plugins/litellm-live-models.js). Add a static entry here only as a
      // fallback for offline use.
      "models": {}
    }
  },
  "model": "litellm/claude-sonnet-4-5",
  "small_model": "litellm/deepseek-chat",
  "plugin": [
    "./plugins/litellm-live-models.js"
  ],
  "mcp": {
    // Single gateway: all MCP upstreams (fastmail, exa, ...) are federated by
    // mcpproxy. Clients never talk to upstreams directly. Bearer token is the
    // scoped downstream agent token from 1Password.
    "mcpproxy": {
      "type": "remote",
      "url": "https://mcp.dev.ankitson.com/mcp",
      "enabled": true,
      "headers": {
        "Authorization": {{ printf "Bearer %s" (onepasswordRead "op://clankers/mcpproxy-agents/password") | quote }}
      }
    }
  }
}
