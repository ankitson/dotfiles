# ble.sh (bash line editor) — required for atuin's full bash integration.
# Sourced with --noattach here; activated with ble-attach at the very end.
if [ -f "$HOME/.local/share/blesh/ble.sh" ]; then
  source "$HOME/.local/share/blesh/ble.sh" --noattach
  # Don't print a "[ble: exit N]" line after every non-zero command.
  bleopt exec_errexit_mark=
fi

# history
shopt -s histappend
HISTSIZE=100000
HISTFILESIZE=200000
HISTTIMEFORMAT='%Y-%m-%d %H:%M  '

# Readline completion behavior
bind 'set show-all-if-ambiguous on'
bind 'set menu-complete-display-prefix on'
bind 'TAB:menu-complete'

# check the window size after each command and, if necessary,
# update the values of LINES and COLUMNS.
shopt -s checkwinsize

# bash prompt
if [ -z "${debian_chroot:-}" ] && [ -r /etc/debian_chroot ]; then
    debian_chroot=$(cat /etc/debian_chroot)
fi
case "$TERM" in
    xterm-color|*-256color|*ghostty) color_prompt=yes;;
esac

GIT_PS1_SHOWDIRTYSTATE=1
GIT_PS1_SHOWSTASHSTATE=1
GIT_PS1_SHOWUNTRACKEDFILES=1
GIT_PS1_SHOWUPSTREAM="auto"
[ -f "$HOME/.git-branch.sh" ] && source "$HOME/.git-branch.sh"

if [ "$color_prompt" = yes ]; then
  if type __git_ps1 &>/dev/null; then
    PS1='\[\033[33m\][\D{%y/%m/%d %H:%M}]\[\033[0m\]${debian_chroot:+($debian_chroot)}\[\033[01;32m\]\u@\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]$(__git_ps1 " (%s)")\$ '
  else
    PS1='${debian_chroot:+($debian_chroot)}\[\033[01;32m\]\u@\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ '
  fi
else
  PS1='${debian_chroot:+($debian_chroot)}\u@\h:\w\$ '
fi
unset color_prompt force_color_prompt

case "$TERM" in
xterm*|rxvt*)
    PS1="\[\e]0;${debian_chroot:+($debian_chroot)}\u@\h: \w\a\]$PS1"
    ;;
esac

# Bash completion
if ! shopt -oq posix; then
  if [ -f /usr/share/bash-completion/bash_completion ]; then
    . /usr/share/bash-completion/bash_completion
  elif [ -f /etc/bash_completion ]; then
    . /etc/bash_completion
  fi
fi

{{ if eq .chezmoi.os "darwin" -}}
# Homebrew
eval "$(/opt/homebrew/bin/brew shellenv)"
{{ end -}}

# ===========
# Environment
# ===========

# 1Password service account token for non-interactive `op read`.
# File lives outside chezmoi/git per-machine — see ~/toolbox/skills/1password-cli/SKILL.md.
[ -f ~/.config/op/service-account.env ] && . ~/.config/op/service-account.env

{{ if lookPath "nvim" -}}
export EDITOR=nvim
{{ else -}}
export EDITOR=vim
{{ end -}}
export CLICOLOR=1
export LS_COLORS+=':ow=01;33'

# C++ (use clang by default if available)
{{ if lookPath "clang" -}}
export CC=clang
export CXX=clang++
{{ end -}}

{{ if .javaHome -}}
export JAVA_HOME={{ .javaHome | quote }}
{{ end -}}

# =============================
# PATH (single consolidated block)
# =============================
{{- $homeDir := .chezmoi.homeDir -}}
{{- $paths := list -}}
{{- /* Home-relative paths (shared) */ -}}
{{- range (list ".local/bin/vendor" "toolbox/bin" "go/bin" ".cargo/bin" ".local/bin" ".local/share/coursier/bin" ".opencode/bin" ".bun/bin") -}}
{{-   $p := joinPath $homeDir . -}}
{{-   if stat $p -}}
{{-     $paths = mustAppend $paths $p -}}
{{-   end -}}
{{- end -}}
{{- /* System paths */ -}}
{{- range (list "/usr/local/go/bin") -}}
{{-   if stat . -}}
{{-     $paths = mustAppend $paths . -}}
{{-   end -}}
{{- end -}}
{{- /* CUDA */ -}}
{{- if .cudaPath -}}
{{-   $paths = mustAppend $paths (printf "%s/bin" .cudaPath) -}}
{{- end -}}
{{- /* Java */ -}}
{{- if .javaHome -}}
{{-   $paths = mustAppend $paths (printf "%s/bin" .javaHome) -}}
{{- end -}}
{{- /* Homeserver-specific */ -}}
{{- if eq .host "homeserver" -}}
{{-   if stat "/home/ankit/hroot/homeserver/bin" -}}
{{-     $paths = mustAppend $paths "/home/ankit/hroot/homeserver/bin" -}}
{{-   end -}}
{{-   if stat "/home/ankit/hroot/homeserver/bin/vendor" -}}
{{-     $paths = mustAppend $paths "/home/ankit/hroot/homeserver/bin/vendor" -}}
{{-   end -}}
{{-   if stat "/home/ankit/hroot/desktop/bin" -}}
{{-     $paths = mustAppend $paths "/home/ankit/hroot/desktop/bin" -}}
{{-   end -}}
{{-   if stat "/home/ankit/hroot/homeserver/bin/vendor" -}}
{{-     $paths = mustAppend $paths "/home/ankit/hroot/desktop/bin/vendor" -}}
{{-   end -}}
{{- end }}
{{ if $paths -}}
export PATH={{ toStrings $paths | join ":" }}:$PATH
{{ end -}}

{{ if .cudaPath -}}
export LD_LIBRARY_PATH="{{ .cudaPath }}/lib64${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
{{ end -}}

# ======================
# Tool initialization
# ======================

# Rust
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# Completions
{{ if lookPath "fzf" -}}
export FZF_COMPLETION_TRIGGER='**'
export FZF_COMPLETION_OPTS='--height 40% --layout=reverse --border'
eval "$(fzf --bash)"
{{ end -}}
{{ if lookPath "terraform" -}}
complete -C "$(which terraform)" terraform
{{ end -}}
{{ if lookPath "uv" -}}
eval "$(uv generate-shell-completion bash)"
{{ end -}}
{{ if lookPath "uvx" -}}
eval "$(uvx --generate-shell-completion bash)"
{{ end -}}

# WezTerm shell integration
WEZTERM_SHELL_INTEGRATION="$HOME/.local/share/wezterm/shell-integration/wezterm.sh"
if [ -n "${WEZTERM_PANE:-}" ] && [ -f "$WEZTERM_SHELL_INTEGRATION" ]; then
  . "$WEZTERM_SHELL_INTEGRATION"
fi
unset WEZTERM_SHELL_INTEGRATION

# Quake terminal session
if [ -n "${QUAKE}" ] && [ -z "${TMUX}" ]; then
  tmux new-session -A -s quake
fi

# atuin — durable, searchable shell history DB (so wezterm scrollback can stay small).
# Local-only by default; `atuin login` enables optional sync. Integrates with ble.sh
# for up-arrow / Ctrl-r search when ble.sh is active.
#
# MUST stay AFTER `fzf --bash` above: both bind Ctrl+R and the last one wins.
# We intentionally let atuin own Ctrl+R (rich DB) while fzf keeps Ctrl+T / Alt+C.
# To hand Ctrl+R back to fzf instead, use: atuin init bash --disable-ctrl-r
if command -v atuin >/dev/null 2>&1; then
  eval "$(atuin init bash)"
fi

# Aliases (after PATH is built)
[ -f "$HOME/.alias.sh" ] && source "$HOME/.alias.sh"

# Activate ble.sh (must be the last line of .bashrc)
[[ ${BLE_VERSION-} ]] && ble-attach
